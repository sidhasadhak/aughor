# The glossary is 97% machine-written: the ontology autodoc appends an `auto_generated: true`
# entry per table whenever a connection is explored, so simply RUNNING the app dirties it
# (1,435 lines from one browser session on 2026-07-24). Tests never touch it — conftest points
# AUGHOR_GLOSSARY_PATH at a throwaway temp copy — so this is purely about the live app.
#
# ⚠️ INERT UNTIL THE FILE IS UNTRACKED. .gitignore does not apply to tracked files, and this one
# is tracked; making it take effect needs `git rm --cached data/glossary.yaml`, which is NOT done
# here because it would drop 4 HAND-AUTHORED entries (customers · daily_revenue · events ·
# kpi_daily — the fixture-DB analyst guidance, referenced by test_fixture_db and test_birth_job)
# out of version control along with the generated noise. Splitting authored from generated is the
# real fix; until then the line stands as the declared intent.
data/glossary.yaml

# Claude Code internal state
.claude/

# Duplicate runtime data under web/
web/data/

# macOS
.DS_Store

# Node
web/node_modules/
web/.next/
web/.env.local

# IDEs
.idea/
.vscode/

# Generated workspace data
data/*.db
data/*.json
data/*.duckdb
# SQLite WAL sidecars — every store now opens in WAL mode (REC-03), so any
# data/*.db can spawn -wal/-shm/-journal companions. Transient; never version.
data/*.db-wal
data/*.db-shm
data/*.db-journal
# DuckDB write-ahead logs / sidecars (transient — never version these)
data/*.duckdb.wal
data/*.duckdb-wal
data/*.duckdb.tmp
*.duckdb.wal

# Eval run artifacts (regenerable — durable outputs are the dataset/harness/FINDINGS)
evals/results*.json
evals/_log*.txt
data/system.db
data/system.db-shm
data/system.db-wal

# Runtime/session artifacts — auto-created backups from platform resets, purges and
# quarantines; runtime finding-dismissal state; and eval output dumps. All disposable
# or regenerable, none belong in the repo. (data/*.json already covers profile/exploration.)
data/_*backup*/
data/_stale_findings_backup_*/
data/finding_dismissals.jsonl
data/ontology_recommendations/
evals/spider2_out/
evals/bakeoff_out/
evals/spider2_afix/
evals/spider2_cand/
evals/spider2_cand_full/
evals/spider2_proj/
evals/spider2_misses_proj/
evals/spider2_probes_smoke/
