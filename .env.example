# Copy to .env and fill in values

# LLM backend: "ollama" (local, default) or "anthropic"
HERMES_BACKEND=ollama

# Ollama model — set to whichever model you have pulled locally
# Run `ollama list` to see available models
# Good options: qwen2.5-coder:7b, qwen2.5-coder:14b, qwen3-coder-next:cloud
HERMES_MODEL=qwen3-coder-next:cloud

# Ollama server URL (default is local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic (only needed if HERMES_BACKEND=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Max investigative iterations before forcing synthesis (default 6)
# HERMES_MAX_ITER=6
