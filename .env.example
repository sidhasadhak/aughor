# Copy to .env and fill in values.
# LLM settings here are the FALLBACK layer: anything saved in Settings → Inference
# in the web UI (data/llm_config.json) takes precedence over this file.

# LLM backend: "ollama" (local, the default) | "lmstudio" (local) |
#              "groq" | "together" | "anthropic" (hosted, need an API key)
AUGHOR_BACKEND=ollama

# ── Ollama (AUGHOR_BACKEND=ollama — the default) ─────────────────────────────
# Needs Ollama running locally (https://ollama.com). CAVEAT: the built-in default
# models are Ollama *cloud-tier* (qwen3-coder-next:cloud / kimi-k2.6:cloud), which
# require `ollama signin`. For a fully-local setup, pull a model and pin it:
#   ollama pull qwen2.5-coder:14b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# AUGHOR_CODER_MODEL=qwen2.5-coder:14b
# AUGHOR_NARRATOR_MODEL=qwen2.5-coder:14b

# ── LM Studio (AUGHOR_BACKEND=lmstudio — local, no key) ──────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# AUGHOR_CODER_MODEL=local-model

# ── Groq (AUGHOR_BACKEND=groq — hosted, key required) ────────────────────────
# GROQ_API_KEY=gsk_...
# AUGHOR_CODER_MODEL=llama-3.3-70b-versatile   # default for groq
# AUGHOR_NARRATOR_MODEL=llama-3.3-70b-versatile

# ── Together (AUGHOR_BACKEND=together — hosted, key required) ────────────────
# TOGETHER_API_KEY=...
# AUGHOR_CODER_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# AUGHOR_NARRATOR_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── Anthropic (AUGHOR_BACKEND=anthropic — hosted, key required) ──────────────
# ANTHROPIC_API_KEY=sk-ant-...

# Max investigative iterations before forcing synthesis (default 6)
# AUGHOR_MAX_ITER=6

# Default Postgres connection — pre-loaded as a built-in on every startup.
# If set, this becomes the default connection in the UI instead of the fixture DB.
# AUGHOR_DEFAULT_POSTGRES_DSN=postgresql://user:pass@localhost:5432/mydb

# SQL Knowledge Base — path to the folder containing SQL pattern and domain knowledge JSONs.
# When set, patterns are embedded into Qdrant and used to guide SQL generation and self-correction.
# AUGHOR_KB_PATH=/absolute/path/to/SQL KB JSONS
# AUGHOR_KB_ENABLED=true   # set to "false" to disable without removing the path

# Vector store used for the knowledge base (docker-compose.yml brings one up).
# AUGHOR_QDRANT_URL=http://localhost:6333

# ── Exposing Aughor beyond localhost ─────────────────────────────────────────
# Aughor's defaults assume a trusted, single-user, local machine. Set these
# before you put it on a network. See SECURITY.md.

# Shared-secret front door. UNSET BY DEFAULT — the API is open. When set, every
# request must carry it as the `X-Api-Key` header (/health, /docs, /redoc and
# /openapi.json stay open so probes and the schema browser keep working).
# AUGHOR_API_KEY=

# Browser origins allowed to call the API.
# Default: http://localhost:3000,http://localhost:3001,http://localhost:3210
# AUGHOR_CORS_ORIGINS=http://localhost:3000

# Fernet key used to encrypt stored connection credentials at rest. If unset, a
# key is generated and written to data/.aughor_key with mode 0600. Set it
# explicitly to share one key across machines — losing it makes saved
# connections undecryptable.
# AUGHOR_SECRET_KEY=

# Require a caller identity (X-Aughor-Org) on every request. Off by default,
# which keeps the single-user local behaviour.
# AUGHOR_REQUIRE_IDENTITY=

# ── Observability (feature flag `obs.mlflow`) ────────────────────────────────
# Trace every investigation to a self-hosted MLflow server (graph nodes, LLM
# calls with token counts, guarded SQL as TOOL spans; searchable by
# tags.investigation_id). Needs the extra:  uv sync --extra observability
# and a server:  docker compose --profile obs up -d mlflow
# AUGHOR_OBS_MLFLOW=1
# AUGHOR_MLFLOW_TRACKING_URI=http://localhost:5001
# AUGHOR_MLFLOW_EXPERIMENT=aughor
